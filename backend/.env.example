DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=pmsdb
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432
# Render sets DATABASE_URL from the managed Postgres connection string.
DATABASE_URL=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_BASE_URL=

MEDIA_ROOT=
COOKIE_SAMESITE=Lax
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# Google Sheets reservation sync (optional).
# Leave GOOGLE_SHEETS_ID blank to keep the integration disabled.
# 1. Create a Google Cloud service account and enable the Sheets API.
# 2. Share the target spreadsheet with the service account email as Editor.
# 3. Set the spreadsheet ID and either a local JSON file path or inline JSON.
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_CREDENTIALS_FILE=google-credentials.json
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_YEAR=0
